#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$SCRIPT_DIR/companion.pid"

if [ ! -f "$PID_FILE" ]; then
  echo "browser companion is not running"
  exit 0
fi

PID="$(cat "$PID_FILE")"
if kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  rm -f "$PID_FILE"
  echo "browser companion stopped"
else
  rm -f "$PID_FILE"
  echo "stale pid file removed"
fi
