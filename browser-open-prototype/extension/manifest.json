{
  "manifest_version": 3,
  "name": "OpenClaw Browser Companion",
  "version": "0.1.0",
  "description": "Minimal companion extension that opens URLs from a local OpenClaw bridge.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://127.0.0.1:3210/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "OpenClaw Browser Companion"
  }
}
